# 🗄️ Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://<projectref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_*

# 🔑 Supabase Secret Key (SERVER ONLY)
# Required for the User Management page (create / edit /
# delete other users via auth.admin.*). NEVER expose this
# to the browser — only read it from Server Components /
# Server Actions. Replaces the old SUPABASE_SERVICE_ROLE_KEY.
# Find it under Supabase Dashboard → Settings → API → Secret keys.
SUPABASE_SECRET_KEY=sb_secret_*